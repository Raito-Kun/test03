# Application
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://crm_user:crm_password@localhost:5432/crm_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars

# Admin (for production seed — dev seed uses hardcoded values)
ADMIN_EMAIL=admin@crm.local
ADMIN_PASSWORD=changeme123

# FusionPBX / FreeSWITCH
ESL_HOST=192.168.1.100
ESL_PORT=8021
ESL_PASSWORD=ClueCon
FUSIONPBX_DOMAIN=pbx.example.com
SIP_GATEWAY=default
FUSIONPBX_RECORDING_URL=http://192.168.1.100:8088

# Webhook Security
WEBHOOK_BASIC_AUTH_USER=crm_webhook
WEBHOOK_BASIC_AUTH_PASS=change-me-webhook-secret
FUSIONPBX_IP=192.168.1.100

# FusionPBX Presence Polling (primary: PG, fallback: SSH + fs_cli)
SIP_PRESENCE_ENABLED=true
FUSIONPBX_PG_USER=fusionpbx_readonly
FUSIONPBX_PG_PASSWORD=
FUSIONPBX_PG_DB=fusionpbx
FUSIONPBX_PG_PORT=5432
FUSIONPBX_PG_SSL=false
FUSIONPBX_SSH_USER=root
FUSIONPBX_SSH_PASSWORD=
