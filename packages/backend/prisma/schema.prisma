generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  super_admin
  admin
  manager
  qa
  leader
  agent
  agent_telesale
  agent_collection
}

enum Gender {
  male
  female
  other
}

enum LeadStatus {
  new
  contacted
  qualified
  proposal
  won
  lost
}

enum DebtTier {
  current
  dpd_1_30
  dpd_31_60
  dpd_61_90
  dpd_90_plus
}

enum DebtStatus {
  active
  in_progress
  promise_to_pay
  paid
  written_off
}

enum CampaignType {
  telesale
  collection
}

enum CampaignStatus {
  draft
  active
  paused
  completed
}

enum CampaignCategory {
  telesale
  collection
  customer_service
}

enum DialMode {
  manual
  auto_dialer
  power_dialer
}

enum WorkSchedule {
  all_day
  business_hours
  custom
}

enum TicketStatus {
  open
  in_progress
  resolved
  closed
}

enum TicketPriority {
  low
  medium
  high
  urgent
}

enum AgentStatus {
  offline
  ready
  break
  ringing
  on_call
  hold
  wrap_up
  transfer
}

enum CallDirection {
  inbound
  outbound
}

enum RecordingStatus {
  available
  failed
  none
}

enum DispositionCategory {
  telesale
  collection
  both
}

enum NotificationType {
  follow_up_reminder
  ptp_due
  system_alert
  campaign_assigned
  recording_failed
  debt_escalated
  sla_breach
}

enum WebhookStatus {
  received
  processed
  failed
  unmatched
}

enum RelationshipType {
  spouse
  parent
  child
  sibling
  guarantor
  colleague
  other
}

enum AuditAction {
  create
  update
  delete
  view
  play_recording
  download
  login
  logout
}

enum UserStatus {
  active
  inactive
}

enum CallMode {
  webrtc
  softphone
}

enum TeamType {
  telesale
  collection
}

// ─── Models ──────────────────────────────────────────────

model User {
  id            String     @id @default(uuid()) @db.Uuid
  email         String     @unique
  passwordHash  String     @map("password_hash")
  fullName      String     @map("full_name")
  role          Role
  teamId        String?    @map("team_id") @db.Uuid
  sipExtension  String?    @map("sip_extension")
  callMode      CallMode   @default(softphone) @map("call_mode")
  status        UserStatus @default(active)
  mustChangePassword Boolean @default(false) @map("must_change_password")
  clusterId     String?    @map("cluster_id") @db.Uuid
  extension     String?    @db.VarChar(20)
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  cluster           PbxCluster?        @relation(fields: [clusterId], references: [id])
  team              Team?              @relation("TeamMembers", fields: [teamId], references: [id])
  ledTeams          Team[]             @relation("TeamLeader")
  contacts          Contact[]          @relation("AssignedContacts")
  createdContacts   Contact[]          @relation("CreatedContacts")
  leads             Lead[]
  debtCases         DebtCase[]
  callLogs          CallLog[]
  qaAnnotations     QaAnnotation[]
  tickets           Ticket[]
  macros            Macro[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  agentStatusLogs   AgentStatusLog[]
  campaignAgents    CampaignAgent[]

  @@map("users")
}

model Team {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  leaderId  String?  @map("leader_id") @db.Uuid
  type      TeamType
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  leader  User?  @relation("TeamLeader", fields: [leaderId], references: [id])
  members User[] @relation("TeamMembers")

  @@map("teams")
}

model Contact {
  id           String   @id @default(uuid()) @db.Uuid
  fullName     String   @map("full_name")
  phone        String
  phoneAlt     String?  @map("phone_alt")
  email        String?
  idNumber     String?  @map("id_number")
  address      String?
  dateOfBirth  DateTime? @map("date_of_birth") @db.Date
  gender       Gender?
  source       String?
  tags         Json?    @db.JsonB
  customFields Json?    @map("custom_fields") @db.JsonB
  occupation    String?   @map("occupation")
  income        Decimal?  @map("income") @db.Decimal(15,2)
  province      String?   @map("province")
  district      String?   @map("district")
  fullAddress   String?   @map("full_address")
  company       String?   @map("company")
  jobTitle      String?   @map("job_title")
  companyEmail  String?   @map("company_email")
  creditLimit   Decimal?  @map("credit_limit") @db.Decimal(15,2)
  bankAccount   String?   @map("bank_account")
  bankName      String?   @map("bank_name")
  internalNotes String?   @map("internal_notes")
  assignedTo   String?  @map("assigned_to") @db.Uuid
  createdBy    String?  @map("created_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  assignedUser   User?   @relation("AssignedContacts", fields: [assignedTo], references: [id])
  createdByUser  User?   @relation("CreatedContacts", fields: [createdBy], references: [id])
  leads          Lead[]
  debtCases      DebtCase[]
  callLogs       CallLog[]
  tickets        Ticket[]
  relationshipsFrom ContactRelationship[] @relation("ContactFrom")
  relationshipsTo   ContactRelationship[] @relation("ContactTo")

  clusterId    String?  @map("cluster_id") @db.Uuid
  cluster      PbxCluster? @relation(fields: [clusterId], references: [id])

  @@index([phone])
  @@index([clusterId])
  @@map("contacts")
}

model Lead {
  id           String     @id @default(uuid()) @db.Uuid
  contactId    String     @map("contact_id") @db.Uuid
  campaignId   String?    @map("campaign_id") @db.Uuid
  status       LeadStatus @default(new)
  score        Int        @default(0)
  leadScore    Int?       @default(0) @map("lead_score")
  product      String?
  budget       Decimal?   @map("budget") @db.Decimal(15, 2)
  assignedTo   String?    @map("assigned_to") @db.Uuid
  nextFollowUp DateTime?  @map("next_follow_up")
  notes        String?
  lostReason   String?    @map("lost_reason")
  wonAmount    Decimal?   @map("won_amount") @db.Decimal(15, 2)
  aiSummary    String?    @map("ai_summary")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  clusterId  String?    @map("cluster_id") @db.Uuid
  contact    Contact   @relation(fields: [contactId], references: [id])
  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  assignedUser User?   @relation(fields: [assignedTo], references: [id])
  cluster    PbxCluster? @relation(fields: [clusterId], references: [id])

  @@index([clusterId])
  @@map("leads")
}

model DebtCase {
  id                String     @id @default(uuid()) @db.Uuid
  contactId         String     @map("contact_id") @db.Uuid
  campaignId        String?    @map("campaign_id") @db.Uuid
  originalAmount    Decimal    @map("original_amount") @db.Decimal(15, 2)
  outstandingAmount Decimal    @map("outstanding_amount") @db.Decimal(15, 2)
  dpd               Int        @default(0)
  tier              DebtTier   @default(current)
  status            DebtStatus @default(active)
  contractNumber    String?    @map("contract_number")
  debtType          String?    @map("debt_type")
  paidAmount        Decimal?   @default(0) @map("paid_amount") @db.Decimal(15, 2)
  remainingAmount   Decimal?   @map("remaining_amount") @db.Decimal(15, 2)
  debtGroup         String?    @map("debt_group")
  dueDate           DateTime?  @map("due_date")
  assignedTo        String?    @map("assigned_to") @db.Uuid
  promiseDate       DateTime?  @map("promise_date") @db.Date
  promiseAmount     Decimal?   @map("promise_amount") @db.Decimal(15, 2)
  aiSummary         String?    @map("ai_summary")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  clusterId  String?    @map("cluster_id") @db.Uuid
  contact    Contact   @relation(fields: [contactId], references: [id])
  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  assignedUser User?   @relation(fields: [assignedTo], references: [id])
  cluster    PbxCluster? @relation(fields: [clusterId], references: [id])

  @@index([clusterId])
  @@map("debt_cases")
}

model CallLog {
  id                String          @id @default(uuid()) @db.Uuid
  callUuid          String          @unique @map("call_uuid")
  contactId         String?         @map("contact_id") @db.Uuid
  userId            String?         @map("user_id") @db.Uuid
  campaignId        String?         @map("campaign_id") @db.Uuid
  direction         CallDirection
  callerNumber      String          @map("caller_number")
  destinationNumber String          @map("destination_number")
  startTime         DateTime        @map("start_time")
  answerTime        DateTime?       @map("answer_time")
  endTime           DateTime?       @map("end_time")
  duration          Int             @default(0)
  billsec           Int             @default(0)
  hangupCause       String?         @map("hangup_cause")
  sipCode           String?         @map("sip_code")
  sipReason         String?         @map("sip_reason")
  dispositionCodeId String?         @map("disposition_code_id") @db.Uuid
  recordingPath     String?         @map("recording_path")
  recordingStatus   RecordingStatus @default(none) @map("recording_status")
  notes             String?
  aiTranscript      String?         @map("ai_transcript")
  aiSummary         String?         @map("ai_summary")
  aiScore           Json?           @map("ai_score") @db.JsonB
  createdAt         DateTime        @default(now()) @map("created_at")

  clusterId      String?         @map("cluster_id") @db.Uuid
  contact        Contact?        @relation(fields: [contactId], references: [id])
  user           User?           @relation(fields: [userId], references: [id])
  campaign       Campaign?       @relation(fields: [campaignId], references: [id])
  dispositionCode DispositionCode? @relation(fields: [dispositionCodeId], references: [id])
  cluster        PbxCluster?     @relation(fields: [clusterId], references: [id])
  qaAnnotations  QaAnnotation[]
  tickets        Ticket[]

  @@index([callUuid])
  @@index([startTime])
  @@index([userId])
  @@index([contactId])
  @@index([clusterId])
  @@map("call_logs")
}

model DispositionCode {
  id               String              @id @default(uuid()) @db.Uuid
  code             String              @unique
  label            String
  category         DispositionCategory
  isFinal          Boolean             @default(false) @map("is_final")
  requiresCallback Boolean             @default(false) @map("requires_callback")
  isActive         Boolean             @default(true) @map("is_active")
  sortOrder        Int                 @default(0) @map("sort_order")

  callLogs                  CallLog[]
  campaignDispositionCodes  CampaignDispositionCode[]

  @@map("disposition_codes")
}

model Campaign {
  id        String         @id @default(uuid()) @db.Uuid
  name      String
  type      CampaignType
  status    CampaignStatus @default(draft)
  startDate DateTime?      @map("start_date") @db.Date
  endDate   DateTime?      @map("end_date") @db.Date
  script        String?
  category      CampaignCategory? @map("category")
  queue         String?
  dialMode      DialMode?         @map("dial_mode")
  callbackUrl   String?           @map("callback_url")
  workSchedule  WorkSchedule?     @map("work_schedule")
  workStartTime String?           @map("work_start_time")
  workEndTime   String?           @map("work_end_time")
  createdBy     String?           @map("created_by") @db.Uuid
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  clusterId String?  @map("cluster_id") @db.Uuid
  leads                     Lead[]
  debtCases                 DebtCase[]
  callLogs                  CallLog[]
  campaignDispositionCodes  CampaignDispositionCode[]
  agents                    CampaignAgent[]
  cluster   PbxCluster? @relation(fields: [clusterId], references: [id])

  @@index([clusterId])
  @@map("campaigns")
}

model CampaignAgent {
  campaignId String   @map("campaign_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([campaignId, userId])
  @@map("campaign_agents")
}

model QaAnnotation {
  id             String   @id @default(uuid()) @db.Uuid
  callLogId      String   @map("call_log_id") @db.Uuid
  reviewerId     String   @map("reviewer_id") @db.Uuid
  score          Int
  criteriaScores Json?    @map("criteria_scores") @db.JsonB
  comment        String?
  timestampNote  Json?    @map("timestamp_note") @db.JsonB
  timestamp      Int?
  category       String?
  createdAt      DateTime @default(now()) @map("created_at")

  callLog  CallLog @relation(fields: [callLogId], references: [id])
  reviewer User    @relation(fields: [reviewerId], references: [id])

  @@map("qa_annotations")
}

model Ticket {
  id          String         @id @default(uuid()) @db.Uuid
  contactId   String         @map("contact_id") @db.Uuid
  callLogId   String?        @map("call_log_id") @db.Uuid
  userId      String         @map("user_id") @db.Uuid
  categoryId  String?        @map("category_id") @db.Uuid
  subject     String
  content     String?
  resultCode  String?        @map("result_code")
  status          TicketStatus   @default(open)
  priority        TicketPriority @default(medium)
  firstResponseAt DateTime?      @map("first_response_at")
  resolvedAt      DateTime?      @map("resolved_at")
  slaBreached     Boolean        @default(false) @map("sla_breached")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  clusterId String?         @map("cluster_id") @db.Uuid
  contact  Contact         @relation(fields: [contactId], references: [id])
  callLog  CallLog?        @relation(fields: [callLogId], references: [id])
  user     User            @relation(fields: [userId], references: [id])
  category TicketCategory? @relation(fields: [categoryId], references: [id])
  cluster  PbxCluster?     @relation(fields: [clusterId], references: [id])

  @@index([clusterId])
  @@map("tickets")
}

model TicketCategory {
  id        String  @id @default(uuid()) @db.Uuid
  name      String
  parentId  String? @map("parent_id") @db.Uuid
  isActive  Boolean @default(true) @map("is_active")
  sortOrder Int     @default(0) @map("sort_order")

  parent   TicketCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children TicketCategory[] @relation("CategoryTree")
  tickets  Ticket[]

  @@map("ticket_categories")
}

model Macro {
  id        String  @id @default(uuid()) @db.Uuid
  name      String
  content   String
  category  String?
  shortcut  String?
  createdBy String  @map("created_by") @db.Uuid
  isGlobal  Boolean @default(false) @map("is_global")
  isActive  Boolean @default(true) @map("is_active")

  creator User @relation(fields: [createdBy], references: [id])

  @@map("macros")
}

model ContactRelationship {
  id               String           @id @default(uuid()) @db.Uuid
  contactId        String           @map("contact_id") @db.Uuid
  relatedContactId String           @map("related_contact_id") @db.Uuid
  relationshipType RelationshipType @map("relationship_type")
  notes            String?
  createdAt        DateTime         @default(now()) @map("created_at")

  contact        Contact @relation("ContactFrom", fields: [contactId], references: [id])
  relatedContact Contact @relation("ContactTo", fields: [relatedContactId], references: [id])

  @@map("contact_relationships")
}

model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String?     @map("user_id") @db.Uuid
  action     AuditAction
  entityType String      @map("entity_type")
  entityId   String?     @map("entity_id") @db.Uuid
  changes    Json?       @db.JsonB
  ipAddress  String?     @map("ip_address")
  userAgent  String?     @map("user_agent")
  createdAt  DateTime    @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@map("audit_logs")
}

model Notification {
  id            String           @id @default(uuid()) @db.Uuid
  userId        String           @map("user_id") @db.Uuid
  type          NotificationType
  title         String
  message       String?
  referenceType String?          @map("reference_type")
  referenceId   String?          @map("reference_id") @db.Uuid
  isRead        Boolean          @default(false) @map("is_read")
  readAt        DateTime?        @map("read_at")
  createdAt     DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model WebhookLog {
  id          String        @id @default(uuid()) @db.Uuid
  source      String
  callUuid    String?       @map("call_uuid")
  rawPayload  String        @map("raw_payload")
  status      WebhookStatus @default(received)
  errorMessage String?      @map("error_message")
  processedAt DateTime?     @map("processed_at")
  createdAt   DateTime      @default(now()) @map("created_at")

  @@map("webhook_logs")
}

model AgentStatusLog {
  id             String      @id @default(uuid()) @db.Uuid
  userId         String      @map("user_id") @db.Uuid
  status         AgentStatus
  reason         String?
  startedAt      DateTime    @default(now()) @map("started_at")
  endedAt        DateTime?   @map("ended_at")
  duration       Int?
  wrapUpDuration Int?        @map("wrap_up_duration")
  createdAt      DateTime    @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("agent_status_logs")
}

model Permission {
  id       String  @id @default(uuid()) @db.Uuid
  key      String  @unique
  label    String
  group    String
  parentId String? @map("parent_id") @db.Uuid
  parent   Permission?  @relation("PermissionHierarchy", fields: [parentId], references: [id])
  children Permission[] @relation("PermissionHierarchy")
  rolePermissions RolePermission[]
  @@map("permissions")
}

model RolePermission {
  role         Role
  permissionId String     @map("permission_id") @db.Uuid
  granted      Boolean    @default(true)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  @@id([role, permissionId])
  @@map("role_permissions")
}

model CampaignDispositionCode {
  campaignId       String @map("campaign_id") @db.Uuid
  dispositionCodeId String @map("disposition_code_id") @db.Uuid
  isActive         Boolean @default(true) @map("is_active")
  sortOrder        Int     @default(0) @map("sort_order")

  campaign        Campaign        @relation(fields: [campaignId], references: [id])
  dispositionCode DispositionCode @relation(fields: [dispositionCodeId], references: [id])

  @@id([campaignId, dispositionCodeId])
  @@map("campaign_disposition_codes")
}

model PbxCluster {
  id                  String   @id @default(uuid()) @db.Uuid
  name                String
  description         String?
  eslHost             String   @map("esl_host")
  eslPort             Int      @default(8021) @map("esl_port")
  eslPassword         String   @map("esl_password")
  sipDomain           String   @map("sip_domain")
  sipWssUrl           String?  @map("sip_wss_url")
  pbxIp               String   @map("pbx_ip")
  gatewayName         String   @map("gateway_name")
  recordingPath       String?  @map("recording_path")
  recordingUrlPrefix  String?  @map("recording_url_prefix")
  cdrReportUrl        String?  @map("cdr_report_url")
  aiApiEndpoint       String?  @map("ai_api_endpoint")
  aiApiKey            String?  @map("ai_api_key")
  smtpHost            String?  @map("smtp_host")
  smtpPort            Int?     @map("smtp_port")
  smtpUser            String?  @map("smtp_user")
  smtpPassword        String?  @map("smtp_password")
  smtpFrom            String?  @map("smtp_from")
  sshUser             String?  @map("ssh_user")
  sshPassword         String?  @map("ssh_password")
  isActive            Boolean  @default(false) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  contacts   Contact[]
  leads      Lead[]
  debtCases  DebtCase[]
  callLogs   CallLog[]
  campaigns  Campaign[]
  tickets    Ticket[]
  extensions   ClusterExtension[]
  featureFlags ClusterFeatureFlag[]
  users        User[]

  @@map("pbx_clusters")
}

model ClusterFeatureFlag {
  id          String   @id @default(uuid()) @db.Uuid
  clusterId   String   @map("cluster_id") @db.Uuid
  domainName  String   @default("") @map("domain_name") @db.VarChar(255)
  featureKey  String   @map("feature_key") @db.VarChar(100)
  isEnabled   Boolean  @default(true) @map("is_enabled")
  updatedBy   String?  @map("updated_by") @db.Uuid
  updatedAt   DateTime @updatedAt @map("updated_at")

  cluster PbxCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)

  @@unique([clusterId, domainName, featureKey])
  @@index([clusterId])
  @@index([clusterId, domainName])
  @@map("cluster_feature_flags")
}

model ClusterExtension {
  id          String   @id @default(uuid()) @db.Uuid
  clusterId   String   @map("cluster_id") @db.Uuid
  extension   String   @db.VarChar(20)
  password    String?  @db.VarChar(255)
  callerName  String?  @map("caller_name") @db.VarChar(255)
  accountcode String?  @db.VarChar(100)
  syncedAt    DateTime @default(now()) @map("synced_at")

  cluster PbxCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)

  @@unique([clusterId, extension])
  @@index([clusterId])
  @@map("cluster_extensions")
}

// ─── Phase 2: Call Scripts ────────────────────────────────

enum ScriptType {
  default
  product
}

model CallScript {
  id        String     @id @default(uuid()) @db.Uuid
  name      String
  type      ScriptType @default(default)
  product   String?
  content   String     @db.Text
  isActive  Boolean    @default(true) @map("is_active")
  sortOrder Int        @default(0) @map("sort_order")
  createdBy String?    @map("created_by") @db.Uuid
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@map("call_scripts")
}
